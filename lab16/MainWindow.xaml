<Window x:Class="lab16.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lab16"
        mc:Ignorable="d"
    Title="Синхронизация потоков (Критические секции)" 
        Height="400" Width="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <TextBlock Grid.Row="0" 
                   Text="Сортировка массива и поиск числа (2 потока)" 
                   FontSize="16" FontWeight="Bold" 
                   Margin="0,0,0,15" HorizontalAlignment="Center"/>


        <TextBlock Grid.Row="1" Text="Исходный массив (через пробел):" FontSize="12" Margin="0,0,0,3"/>
        <TextBox Grid.Row="2" 
                 Text="{Binding InputArray, UpdateSourceTrigger=PropertyChanged}" 
                 FontSize="14" Padding="5" Margin="0,0,0,10"/>

       
        <TextBlock Grid.Row="3" Text="Число для поиска:" FontSize="12" Margin="0,0,0,3"/>
        <TextBox Grid.Row="4" 
                 Text="{Binding SearchNumber, UpdateSourceTrigger=PropertyChanged}" 
                 FontSize="14" Padding="5" Margin="0,0,0,15"/>


        <Button Grid.Row="5" 
                Content="Запустить потоки" 
                Command="{Binding StartCommand}"
                FontSize="14" Padding="15,8" 
                HorizontalAlignment="Center"
                Margin="0,0,0,15"/>


        <Border Grid.Row="6" Background="#FFF0F0F0" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <TextBlock Text="{Binding Status}" FontSize="13" FontStyle="Italic" Foreground="#FF333333"/>
        </Border>

       
        <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="0,0,0,5">
            <TextBlock Text="Отсортированный массив: " FontSize="13" FontWeight="Bold"/>
            <TextBlock Text="{Binding SortedArray}" FontSize="13" Foreground="DarkBlue"/>
        </StackPanel>

        
        <StackPanel Grid.Row="8" Orientation="Horizontal">
            <TextBlock Text="Результат поиска: " FontSize="13" FontWeight="Bold"/>
            <TextBlock Text="{Binding SearchResult}" FontSize="13" Foreground="DarkGreen" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
